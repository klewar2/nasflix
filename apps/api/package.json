{
  "name": "@nasflix/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "prisma generate && nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy"
  },
  "dependencies": {
    "@nasflix/shared": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^11",
    "@nestjs/passport": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^5",
    "@nestjs/websockets": "^11.1.16",
    "@prisma/client": "^6",
    "bcryptjs": "^2",
    "bullmq": "^5.70.4",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "parse-torrent-title": "^2",
    "passport": "^0.7",
    "passport-jwt": "^4",
    "passport-local": "^1",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@types/bcryptjs": "^2",
    "@types/express": "^5",
    "@types/node": "^22",
    "@types/passport-jwt": "^4",
    "@types/passport-local": "^1",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "prisma": "^6",
    "typescript": "^5.7",
    "typescript-eslint": "^8.57.0"
  }
}
