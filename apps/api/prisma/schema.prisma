datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum MediaType {
  MOVIE
  SERIES
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
  NOT_FOUND
}

enum MemberRole {
  ADMIN
  VIEWER
}

enum SourceType {
  NAS
  SEEDBOX
}

enum StreamingQuality {
  NATIVE
  DIRECT
}

enum JobKind {
  DOWNLOAD_TO_NAS
  DELETE_FROM_SEEDBOX
  DELETE_FROM_JELLYFIN
}

enum JobSource {
  RADARR
  SONARR
  MANUAL
  NAS_SYNC
}

enum JobStatus {
  PENDING
  AWAITING_NAS
  AWAITING_SEEDBOX
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id           Int              @id @default(autoincrement())
  username     String           @unique
  email        String?
  firstName    String
  lastName     String
  passwordHash String
  isSuperAdmin     Boolean          @default(false)
  streamingQuality StreamingQuality @default(NATIVE)
  lastLoginAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  memberships      CineClubMember[]
}

model CineClub {
  id               Int              @id @default(autoincrement())
  name             String
  slug             String           @unique
  nasBaseUrl       String?
  nasSharedFolders String[]         @default([])
  tmdbApiKey       String?
  webhookSecret    String?          @unique
  nasWolMac        String?
  nasWolHost       String?
  nasWolPort       Int?
  freeboxApiUrl    String?
  freeboxAppToken  String?
  jellyfinBaseUrl  String?
  jellyfinApiToken String?
  // Radarr / Sonarr
  radarrBaseUrl    String?
  radarrApiKey     String?
  sonarrBaseUrl    String?
  sonarrApiKey     String?
  // SSH seedbox (Nasflix → seedbox)
  seedboxSshHost       String?
  seedboxSshPort       Int      @default(22)
  seedboxSshUser       String?
  seedboxSshPrivateKey String?
  seedboxSshPassphrase String?
  // SSH NAS (rsync target depuis seedbox)
  nasSshHost           String?
  nasSshPort           Int      @default(22)
  nasSshUser           String?
  // Chemin absolu sur la seedbox vers la clé privée SSH autorisée sur le NAS
  // (ex. /home/klewar/.ssh/nas_receive). Si vide, rsync utilise ~/.ssh/config seedbox.
  seedboxToNasKeyPath  String?
  nasTargetMovieDir    String?
  nasTargetSeriesDir   String?
  // Wake-on-LAN
  nasWolWaitSeconds    Int      @default(300)
  // Grâce suppression seedbox
  seedboxDeleteGraceHours Int   @default(24)
  // Gmail (notifications super admin)
  gmailFrom            String?
  gmailAppPassword     String?
  gmailEnabled         Boolean  @default(false)
  lastOnlineAt     DateTime?
  lastSyncAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  members          CineClubMember[]
  media            Media[]
  syncLogs         SyncLog[]
  jobs             Job[]
}

model CineClubMember {
  id          Int        @id @default(autoincrement())
  userId      Int
  cineClubId  Int
  role        MemberRole @default(VIEWER)
  nasUsername String?
  nasPassword String?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cineClub    CineClub   @relation(fields: [cineClubId], references: [id], onDelete: Cascade)

  @@unique([userId, cineClubId])
}

model Media {
  id            Int           @id @default(autoincrement())
  cineClubId    Int
  type          MediaType
  titleVf       String?
  titleOriginal String
  nasPath       String
  nasFilename   String
  nasSize       BigInt?
  nasAddedAt    DateTime?
  videoQuality  String?
  hdr           Boolean       @default(false)
  dolbyVision   Boolean       @default(false)
  dolbyAtmos    Boolean       @default(false)
  audioFormat   String?
  tmdbId        Int?
  overview      String?
  posterUrl     String?
  backdropUrl   String?
  trailerUrl    String?
  releaseDate   DateTime?
  releaseYear   Int?
  runtime       Int?
  voteAverage   Float?
  sourceType    SourceType    @default(NAS)
  jellyfinItemId String?
  syncStatus    SyncStatus    @default(PENDING)
  lastSyncedAt  DateTime?
  syncError     String?
  nasDeletedAt  DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  cineClub      CineClub      @relation(fields: [cineClubId], references: [id], onDelete: Cascade)
  genres        MediaGenre[]
  cast          MediaPerson[]
  seasons       Season[]
  jobs          Job[]

  @@unique([cineClubId, nasPath])
  @@index([cineClubId, type])
  @@index([cineClubId, syncStatus])
  @@index([cineClubId, titleVf])
  @@index([cineClubId, releaseYear])
  @@index([cineClubId, createdAt])
}

model Genre {
  id     Int          @id @default(autoincrement())
  tmdbId Int          @unique
  name   String
  media  MediaGenre[]
}

model MediaGenre {
  mediaId Int
  genreId Int
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([mediaId, genreId])
}

model Person {
  id       Int           @id @default(autoincrement())
  tmdbId   Int           @unique
  name     String
  photoUrl String?
  media    MediaPerson[]
}

model MediaPerson {
  id        Int    @id @default(autoincrement())
  role      String
  character String?
  order     Int    @default(0)
  mediaId   Int
  personId  Int
  media     Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  person    Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([mediaId, personId, role])
  @@index([mediaId, role])
}

model Season {
  id           Int       @id @default(autoincrement())
  seasonNumber Int
  name         String?
  overview     String?
  posterUrl    String?
  episodeCount Int?
  airDate      DateTime?
  mediaId      Int
  media        Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episodes     Episode[]

  @@unique([mediaId, seasonNumber])
}

model Episode {
  id            Int       @id @default(autoincrement())
  episodeNumber Int
  name          String?
  overview      String?
  runtime       Int?
  airDate       DateTime?
  stillUrl      String?
  nasPath       String?   @unique
  nasFilename   String?
  nasSize       BigInt?
  sourceType    SourceType @default(NAS)
  jellyfinItemId String?
  nasDeletedAt  DateTime?
  seasonId      Int
  season        Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  jobs          Job[]

  @@unique([seasonId, episodeNumber])
}

model SubtitleCache {
  id         Int      @id @default(autoincrement())
  mediaId    Int?
  episodeId  Int?
  trackIdx   Int
  language   String
  title      String
  codec      String
  vttContent String   @db.Text
  createdAt  DateTime @default(now())

  @@index([mediaId])
  @@index([episodeId])
}

model SyncLog {
  id             Int       @id @default(autoincrement())
  cineClubId     Int?
  type           String
  status         String
  totalItems     Int?
  processedItems Int?
  errorCount     Int?
  errorDetails   String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  triggeredBy    String?
  cineClub       CineClub? @relation(fields: [cineClubId], references: [id], onDelete: SetNull)
}

model Job {
  id               Int        @id @default(autoincrement())
  cineClubId       Int
  cineClub         CineClub   @relation(fields: [cineClubId], references: [id], onDelete: Cascade)

  kind             JobKind
  source           JobSource
  status           JobStatus  @default(PENDING)

  tmdbId           Int?
  tmdbType         String?
  mediaId          Int?
  media            Media?     @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  episodeId        Int?
  episode          Episode?   @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  seriesTitle      String?
  seasonNumber     Int?
  episodeNumber    Int?

  sourcePath       String?
  fileName         String?
  fileSize         BigInt?
  targetPath       String?

  jellyfinItemId   String?

  scheduledFor     DateTime?

  attempts         Int        @default(0)
  errorMessage     String?
  errorDetails     Json?
  progressPercent  Int?
  triggeredBy      String?

  createdAt        DateTime   @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?

  @@index([cineClubId, kind, status])
  @@index([status, scheduledFor])
  @@index([createdAt])
}
