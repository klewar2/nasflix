datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum MediaType {
  MOVIE
  SERIES
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
  NOT_FOUND
}

model Media {
  id              Int         @id @default(autoincrement())
  type            MediaType
  titleVf         String?
  titleOriginal   String
  nasPath         String      @unique
  nasFilename     String
  nasSize         BigInt?
  tmdbId          Int?        @unique
  overview        String?
  posterUrl       String?
  backdropUrl     String?
  trailerUrl      String?
  releaseDate     DateTime?
  releaseYear     Int?
  runtime         Int?
  voteAverage     Float?
  syncStatus      SyncStatus  @default(PENDING)
  lastSyncedAt    DateTime?
  syncError       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  genres          MediaGenre[]
  cast            MediaPerson[]
  seasons         Season[]

  @@index([type])
  @@index([syncStatus])
  @@index([titleVf])
  @@index([releaseYear])
  @@index([createdAt])
}

model Genre {
  id        Int          @id @default(autoincrement())
  tmdbId    Int          @unique
  name      String
  media     MediaGenre[]
}

model MediaGenre {
  mediaId   Int
  genreId   Int
  media     Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  genre     Genre   @relation(fields: [genreId], references: [id], onDelete: Cascade)
  @@id([mediaId, genreId])
}

model Person {
  id        Int            @id @default(autoincrement())
  tmdbId    Int            @unique
  name      String
  photoUrl  String?
  media     MediaPerson[]
}

model MediaPerson {
  id          Int      @id @default(autoincrement())
  role        String
  character   String?
  order       Int      @default(0)
  mediaId     Int
  media       Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  personId    Int
  person      Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  @@unique([mediaId, personId, role])
  @@index([mediaId, role])
}

model Season {
  id              Int       @id @default(autoincrement())
  seasonNumber    Int
  name            String?
  overview        String?
  posterUrl       String?
  episodeCount    Int?
  airDate         DateTime?
  mediaId         Int
  media           Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  episodes        Episode[]
  @@unique([mediaId, seasonNumber])
}

model Episode {
  id              Int       @id @default(autoincrement())
  episodeNumber   Int
  name            String?
  overview        String?
  runtime         Int?
  airDate         DateTime?
  stillUrl        String?
  nasPath         String?   @unique
  nasFilename     String?
  nasSize         BigInt?
  seasonId        Int
  season          Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  @@unique([seasonId, episodeNumber])
}

model NasConfig {
  id              Int       @id @default(autoincrement())
  name            String    @default("primary") @unique
  baseUrl         String
  username        String
  passwordEnc     String
  sharedFolders   String[]
  isActive        Boolean   @default(true)
  lastOnlineAt    DateTime?
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ApiConfig {
  id              Int       @id @default(autoincrement())
  provider        String    @unique
  apiKey          String
  baseUrl         String
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SyncLog {
  id              Int       @id @default(autoincrement())
  type            String
  status          String
  totalItems      Int?
  processedItems  Int?
  errorCount      Int?
  errorDetails    String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  triggeredBy     String?
}
